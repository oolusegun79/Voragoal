generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  GUEST
  USER
  EDITOR
  ADMIN
}

enum MatchStage {
  GROUP
  R32
  R16
  QF
  SF
  THIRD_PLACE
  FINAL
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum EventType {
  GOAL
  OWN_GOAL
  PENALTY_GOAL
  PENALTY_MISS
  ASSIST
  YELLOW_CARD
  RED_CARD
  SUB_IN
  SUB_OUT
  VAR
  INJURY
}

enum SubjectType {
  MATCH
  TEAM
  PLAYER
}

enum Position {
  GK
  DF
  MF
  FW
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  passwordHash      String?                                                  // null for OAuth-only accounts (e.g. Google)
  name              String?
  avatarUrl         String?
  role              Role             @default(USER)
  hasTournamentPass Boolean          @default(false)
  passPurchasedAt   DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  favoriteTeams     FavoriteTeam[]
  favoritePlayers   FavoritePlayer[]
  savedMatches      SavedMatch[]
  sessions          Session[]
  accounts          Account[]
  purchases         Purchase[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique                                                  // sha256 of the random token sent in email
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  @@index([userId])
  @@index([expiresAt])
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

model Purchase {
  id                    String         @id @default(cuid())
  userId                String
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  product               String                                              // "tournament_pass"
  amountCents           Int
  currency              String                                              // "usd"
  status                PurchaseStatus @default(PENDING)
  stripeSessionId       String         @unique
  stripePaymentIntentId String?
  createdAt             DateTime       @default(now())
  completedAt           DateTime?

  @@index([userId])
}

// NextAuth Prisma adapter tables — kept for future OAuth providers.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Team {
  id            String           @id // ISO-3, e.g. "BRA"
  name          String
  shortName     String
  flagEmoji     String
  accentColor   String           @default("#1D9BF0")
  groupCode     String?
  fifaRanking   Int?
  manager       String?
  squad         Player[]
  homeMatches   Match[]          @relation("home")
  awayMatches   Match[]          @relation("away")
  goalsEvents   MatchEvent[]     @relation("eventTeam")
  matchStats    MatchStat[]
  favoritedBy   FavoriteTeam[]
}

model Player {
  id            String           @id @default(cuid())
  fullName      String
  knownAs       String?
  teamId        String
  team          Team             @relation(fields: [teamId], references: [id])
  position      Position
  shirtNumber   Int?
  birthDate     DateTime?
  club          String?
  heightCm      Int?
  events        MatchEvent[]     @relation("primaryPlayer")
  relatedEvents MatchEvent[]     @relation("relatedPlayer")
  favoritedBy   FavoritePlayer[]
  externalApiId String?

  @@index([teamId])
  @@index([teamId, externalApiId])
}

model Venue {
  id       String  @id @default(cuid())
  name     String
  city     String
  country  String
  capacity Int?
  matches  Match[]
}

model Match {
  id                   String       @id @default(cuid())
  stage                MatchStage
  groupCode            String?
  matchNumber          Int          @unique
  kickoffAt            DateTime
  status               MatchStatus  @default(SCHEDULED)
  homeTeamId           String
  awayTeamId           String
  homeTeam             Team         @relation("home", fields: [homeTeamId], references: [id])
  awayTeam             Team         @relation("away", fields: [awayTeamId], references: [id])
  homeScore            Int?
  awayScore            Int?
  homePenalties        Int?
  awayPenalties        Int?
  kickoffStartedAt     DateTime?
  secondHalfStartedAt  DateTime?
  addedMinutes1H       Int?
  addedMinutes2H       Int?
  venueId              String?
  venue                Venue?       @relation(fields: [venueId], references: [id])
  referee              String?
  attendance           Int?
  events               MatchEvent[]
  stats                MatchStat[]
  savedBy              SavedMatch[]
  externalApiId        String?

  @@index([kickoffAt])
  @@index([stage])
  @@index([homeTeamId, awayTeamId])
}

model MatchEvent {
  id              String     @id @default(cuid())
  matchId         String
  match           Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  minute          Int
  addedMinute     Int?
  type            EventType
  teamId          String
  team            Team       @relation("eventTeam", fields: [teamId], references: [id])
  playerId        String?
  player          Player?    @relation("primaryPlayer", fields: [playerId], references: [id])
  relatedPlayerId String?
  relatedPlayer   Player?    @relation("relatedPlayer", fields: [relatedPlayerId], references: [id])
  detail          String?
  externalEventKey String?
  importedFromFeed Boolean   @default(false)

  @@index([matchId, minute])
  @@unique([matchId, externalEventKey])
}

model MatchStat {
  id            String @id @default(cuid())
  matchId       String
  match         Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  teamId        String
  team          Team   @relation(fields: [teamId], references: [id])
  possession    Float?
  shots         Int?
  shotsOnTarget Int?
  corners       Int?
  fouls         Int?
  offsides      Int?
  xG            Float?
  passes        Int?
  passAccuracy  Float?

  @@unique([matchId, teamId])
}

model FavoriteTeam {
  userId    String
  teamId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id])

  @@id([userId, teamId])
}

model FavoritePlayer {
  userId    String
  playerId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id])

  @@id([userId, playerId])
}

model SavedMatch {
  userId    String
  matchId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match     Match    @relation(fields: [matchId], references: [id])

  @@id([userId, matchId])
}

model AiSummary {
  id          String      @id @default(cuid())
  subjectType SubjectType
  subjectId   String
  contentMd   String
  modelId     String
  dataHash    String
  createdAt   DateTime    @default(now())

  @@unique([subjectType, subjectId, dataHash])
  @@index([subjectType, subjectId])
}
